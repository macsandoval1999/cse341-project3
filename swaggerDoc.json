{
  "swagger": "2.0",
  "info": {
    "title": "CSE341 Project 3 API: ESO Guilds API",
    "description": "This API provides endpoints to manage guilds and players in the Elder Scrolls Online (ESO) game. It allows users to create, read, update, and delete guilds and players, as well as manage player memberships in guilds.",
    "version": "1.0.0"
  },
  "host": "cse341-project3.onrender.com",
  "basePath": "/",
  "tags": [
    {
      "name": "Guilds",
      "description": "Guild management endpoints. Guild write requests enforce guild master ownership rules and keep player guild membership in sync."
    },
    {
      "name": "Players",
      "description": "Player management endpoints. Player write requests validate request fields and ensure any provided guild_id points to an existing guild."
    }
  ],
  "schemes": [
    "https"
  ],
  "paths": {
    "/guilds/": {
      "get": {
        "tags": [
          "Guilds"
        ],
        "summary": "Get all guilds",
        "description": "Returns every guild in the collection.",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Guilds"
        ],
        "summary": "Create a guild",
        "description": "Creates a new guild. Special rule: the guildMaster must be an existing player and cannot already be the guild master of another guild. On success, that player\\'s guild_id is synced to the new guild.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Full guild payload. The guildMaster value must be a valid player ObjectId and that player can only be guild master of one guild at a time.",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Covenant of Shadows"
                },
                "tag": {
                  "type": "string",
                  "example": "CoS"
                },
                "description": {
                  "type": "string",
                  "example": "A guild focused on PvP content"
                },
                "alliance": {
                  "type": "string",
                  "example": "Aldmeri Dominion"
                },
                "memberCount": {
                  "type": "number",
                  "example": 1
                },
                "createdAt": {
                  "type": "string",
                  "example": "2024-01-01"
                },
                "activities": {
                  "type": "array",
                  "example": [
                    "Raid",
                    "Dungeon"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "ranks": {
                  "type": "array",
                  "example": [
                    "Guild Master",
                    "Officer",
                    "Member"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "recruitmentOpen": {
                  "type": "boolean",
                  "example": true
                },
                "language": {
                  "type": "string",
                  "example": "English"
                },
                "region": {
                  "type": "string",
                  "example": "NA"
                },
                "guildMaster": {
                  "type": "string",
                  "example": "607c191e810c19729de860ea"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      }
    },
    "/guilds/{id}": {
      "get": {
        "tags": [
          "Guilds"
        ],
        "summary": "Get a guild by id",
        "description": "Returns a single guild by its MongoDB ObjectId.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": [
          "Guilds"
        ],
        "summary": "Replace a guild",
        "description": "Replaces a guild document by id. All guild fields are required. If guildMaster changes, the previous guild master is cleared from this guild and the new guild master is synced. A player cannot become guild master of more than one guild.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Complete replacement payload for a guild.",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Nightfall Raiders"
                },
                "tag": {
                  "type": "string",
                  "example": "NR"
                },
                "description": {
                  "type": "string",
                  "example": "A guild focused on endgame content"
                },
                "alliance": {
                  "type": "string",
                  "example": "Daggerfall Covenant"
                },
                "memberCount": {
                  "type": "number",
                  "example": 20
                },
                "createdAt": {
                  "type": "string",
                  "example": "2024-02-01"
                },
                "activities": {
                  "type": "array",
                  "example": [
                    "Raid",
                    "PvP"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "ranks": {
                  "type": "array",
                  "example": [
                    "Guild Master",
                    "Officer",
                    "Member"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "recruitmentOpen": {
                  "type": "boolean",
                  "example": false
                },
                "language": {
                  "type": "string",
                  "example": "English"
                },
                "region": {
                  "type": "string",
                  "example": "EU"
                },
                "guildMaster": {
                  "type": "string",
                  "example": "607c191e810c19729de860eb"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      },
      "patch": {
        "tags": [
          "Guilds"
        ],
        "summary": "Update a guild",
        "description": "Partially updates a guild by id. If guildMaster is provided, it must reference an existing player who is not already guild master of another guild. When changed, player guild_id values are synced automatically.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Partial guild payload. Include only the fields you want to change.",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Nightfall Raiders"
                },
                "tag": {
                  "type": "string",
                  "example": "NR"
                },
                "description": {
                  "type": "string",
                  "example": "A guild focused on endgame content"
                },
                "alliance": {
                  "type": "string",
                  "example": "Daggerfall Covenant"
                },
                "memberCount": {
                  "type": "number",
                  "example": 20
                },
                "createdAt": {
                  "type": "string",
                  "example": "2024-02-01"
                },
                "activities": {
                  "type": "array",
                  "example": [
                    "Raid",
                    "PvP"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "ranks": {
                  "type": "array",
                  "example": [
                    "Guild Master",
                    "Officer",
                    "Member"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "recruitmentOpen": {
                  "type": "boolean",
                  "example": false
                },
                "language": {
                  "type": "string",
                  "example": "English"
                },
                "region": {
                  "type": "string",
                  "example": "EU"
                },
                "guildMaster": {
                  "type": "string",
                  "example": "607c191e810c19729de860eb"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Guilds"
        ],
        "summary": "Delete a guild",
        "description": "Deletes a guild by id. Special rule: all players whose guild_id points to this guild are automatically cleared to null.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      }
    },
    "/players/": {
      "get": {
        "tags": [
          "Players"
        ],
        "summary": "Get all players",
        "description": "Returns every player in the collection.",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Players"
        ],
        "summary": "Create a player",
        "description": "Creates a new player. If guild_id is provided, it must reference an existing guild.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Full player payload. The stats field must be a plain object when provided.",
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string",
                  "example": "Molag Bal"
                },
                "displayName": {
                  "type": "string",
                  "example": "Molag Bal"
                },
                "level": {
                  "type": "number",
                  "example": 1
                },
                "championPoints": {
                  "type": "number",
                  "example": 0
                },
                "class": {
                  "type": "string",
                  "example": "Warrior"
                },
                "alliance": {
                  "type": "string",
                  "example": "Aldmeri Dominion"
                },
                "joinDate": {
                  "type": "string",
                  "example": "2024-01-01"
                },
                "role": {
                  "type": "string",
                  "example": "Tank"
                },
                "achievements": {
                  "type": "array",
                  "example": [],
                  "items": {}
                },
                "stats": {
                  "type": "object",
                  "properties": {}
                },
                "email": {
                  "type": "string",
                  "example": "molagbal@example.com"
                },
                "bio": {
                  "type": "string",
                  "example": "This is Molag Bal"
                },
                "guild_id": {
                  "type": "string",
                  "example": "607c191e810c19729de860ea"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      }
    },
    "/players/{id}": {
      "get": {
        "tags": [
          "Players"
        ],
        "summary": "Get a player by id",
        "description": "Returns a single player by its MongoDB ObjectId.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": [
          "Players"
        ],
        "summary": "Replace a player",
        "description": "Replaces a player document by id. All player fields are expected. If guild_id is provided, it must reference an existing guild.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Complete replacement payload for a player.",
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string",
                  "example": "Molag Bal"
                },
                "displayName": {
                  "type": "string",
                  "example": "Molag Bal"
                },
                "level": {
                  "type": "number",
                  "example": 1
                },
                "championPoints": {
                  "type": "number",
                  "example": 0
                },
                "class": {
                  "type": "string",
                  "example": "Warrior"
                },
                "alliance": {
                  "type": "string",
                  "example": "Aldmeri Dominion"
                },
                "joinDate": {
                  "type": "string",
                  "example": "2024-01-01"
                },
                "role": {
                  "type": "string",
                  "example": "Tank"
                },
                "achievements": {
                  "type": "array",
                  "example": [],
                  "items": {}
                },
                "stats": {
                  "type": "object",
                  "properties": {}
                },
                "email": {
                  "type": "string",
                  "example": "molagbal@example.com"
                },
                "bio": {
                  "type": "string",
                  "example": "This is Molag Bal"
                },
                "guild_id": {
                  "type": "string",
                  "example": "607c191e810c19729de860ea"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      },
      "patch": {
        "tags": [
          "Players"
        ],
        "summary": "Update a player",
        "description": "Partially updates a player by id. If guild_id is included, it must reference an existing guild or be null to clear membership.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "description": "Partial player payload. Include only the fields you want to change.",
            "schema": {
              "type": "object",
              "properties": {
                "guild_id": {
                  "type": "string",
                  "example": "607c191e810c19729de860ea"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Players"
        ],
        "summary": "Delete a player",
        "description": "Deletes a player by id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "sessionAuth": []
          }
        ]
      }
    }
  }
}